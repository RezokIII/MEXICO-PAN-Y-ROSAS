title: Next month
set-bg: img/fondo_escritorio.jpg
is-hand: true
on-arrival: {!
// FIX: migrate cards stranded in other era-hands into this hand
// (hands are stored per-scene-id; the 1978/1985 hand upgrades used to wipe the hand)
var _me = this.state.sceneId;
var _hands = this.state.currentHands;
if (!_hands[_me]) { _hands[_me] = []; }
var _eras = ['main', 'main.main_78', 'main.main_85', 'main.main_easy'];
for (var _hi = 0; _hi < _eras.length; _hi++) {
    var _h = _eras[_hi];
    if (_h === _me || !_hands[_h] || !_hands[_h].length) { continue; }
    while (_hands[_h].length) { _hands[_me].push(_hands[_h].shift()); }
}
if (Q.advisor_action_timer <= 0) {
    Q.pinnedCardsDescription = 'Advisors - an action is available.';
} else if (Q.advisor_action_timer == 1) {
    Q.pinnedCardsDescription = 'Advisors - next action available in 1 month.';
} else {
    Q.pinnedCardsDescription = 'Advisors - next action available in ' + Q.advisor_action_timer + ' months.';
}
// event-queue loop: if more events are still pending this month, keep resolving them
var _es = this.game.scenes['post_event.events_choice'];
var _ch = this._compileChoices(_es);
Q.has_event = (_ch && _ch[0] && _ch[0].title != "Continue...") ? 1 : 0;
if (Q.has_event == 0) { Q.pending_events = 0; }
!}
go-to: post_event.events_choice if pending_events = 1
max-cards: 3

#Here, the main deck will be displayed. Clicking on the deck draws a card into your hand. Clicking on a card activates that card.

[? if year = 1928 and month = 2 : The current bourgeois-right government has fallen. The next elections are slated for May of this year. ?]

- @movimiento
- @sistema
- @canales
- @sierra
- @fdn
- #advisor
- @shuffle_leadership_pinned

