Q.advisor_action_timer = 6; Q.last_advisor_action = 1;
if (Q.via == 'armada') { Q.pres_valle += 3; Q.guerrilla_meter += 2; Q.expediente += 4; }
else { Q.sup_colonos += 2; Q.colonia_presion += 1; Q.represion -= 1; Q.expediente += 2; }
