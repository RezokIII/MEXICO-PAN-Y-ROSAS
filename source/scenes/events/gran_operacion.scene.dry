Q.represion -= 6; Q.guerrilla_meter -= 4;
Q.veteranos = Math.max(Q.veteranos, Math.round(Q.pres_total / 15));
Q.members += 2 + Math.min(5, Math.floor(Q.pres_total / 20));
Q.organizers += 1 + (Q.pres_total >= 50 ? 1 : 0);
Q.red_casillas += Math.min(12, Math.floor(Q.pres_guerrero / 5) + Math.floor(Q.pres_oaxaca / 5));
Q.sup_peasants += Math.min(10, 3 + Q.pres_total * 0.06);
